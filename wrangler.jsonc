{
  // Cloudflare Worker config — Biscuit Market Intelligence dashboard.
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "biscuitdashboard",
  "main": "worker.js",
  "compatibility_date": "2025-06-01",

  // Serve the dashboard (index.html), the CI-committed data/*.json, and static
  // assets. SPA fallback routes unknown paths back to index.html.
  "assets": {
    "directory": "./",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  }
}
